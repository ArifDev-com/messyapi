{
    "name": "kstmostofa/laravel-whatsapp",
    "description": "Dual-backend Laravel package for WhatsApp: Meta Cloud API + bundled whatsapp-web.js sidecar. Ships a Livewire/Flux admin UI, queued jobs, webhooks with HMAC, Eloquent models, broadcasting, and CLI lifecycle commands.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "whatsapp",
        "whatsapp-business",
        "whatsapp-cloud-api",
        "whatsapp-web",
        "whatsapp-web-js",
        "meta",
        "messaging",
        "chatbot",
        "webhooks",
        "livewire",
        "flux"
    ],
    "authors": [
        {
            "name": "Md Mostafijur Rahman",
            "email": "mostofa122@gmail.com",
            "homepage": "https://github.com/kstmostofa"
        }
    ],
    "homepage": "https://kstmostofa.github.io/laravel-whatsapp/",
    "support": {
        "issues": "https://github.com/kstmostofa/laravel-whatsapp/issues",
        "source": "https://github.com/kstmostofa/laravel-whatsapp",
        "docs": "https://kstmostofa.github.io/laravel-whatsapp/"
    },
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.5",
        "symfony/process": "^7.0|^8.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0",
        "livewire/livewire": "^3.4|^4.0",
        "livewire/flux": "^2.0"
    },
    "suggest": {
        "livewire/livewire": "^3.4 — enables the bundled admin UI.",
        "livewire/flux": "^2.0 — the Flux UI component library the bundled UI is built on.",
        "laravel/reverb": "^1.0 — enables live UI updates (incoming messages, QR codes, ack changes) via Laravel broadcasting."
    },
    "autoload": {
        "psr-4": {
            "Kstmostofa\\LaravelWhatsApp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kstmostofa\\LaravelWhatsApp\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kstmostofa\\LaravelWhatsApp\\LaravelWhatsAppServiceProvider"
            ],
            "aliases": {
                "WhatsApp": "Kstmostofa\\LaravelWhatsApp\\Facades\\WhatsApp"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-text"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}